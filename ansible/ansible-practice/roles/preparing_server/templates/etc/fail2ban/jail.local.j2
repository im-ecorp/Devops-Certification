# fail2ban jail.local
# Managed by Ansible role preparing_server — do not edit manually

[DEFAULT]
backend = {{ linux_fail2ban_backend }}
ignoreip = {{ linux_fail2ban_whitelist_ips | join(' ') }}
bantime = {{ linux_fail2ban_ssh_bantime }}
findtime = {{ linux_fail2ban_ssh_findtime }}
maxretry = {{ linux_fail2ban_ssh_maxretry }}

{% if linux_fail2ban_ssh_enabled | bool %}
[sshd]
enabled = true
port    = {{ linux_fail2ban_ssh_port }}
filter  = {{ linux_fail2ban_ssh_filter }}
logpath = {{ linux_fail2ban_ssh_logpath }}
maxretry = {{ linux_fail2ban_ssh_maxretry }}
bantime  = {{ linux_fail2ban_ssh_bantime }}
findtime = {{ linux_fail2ban_ssh_findtime }}
{% endif %}
